{
  "name": "minimal-boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "docker": "./docker/start.sh",
    "dev": "concurrently --raw --kill-others pnpm:dev:*",
    "dev:next": "next dev --turbopack",
    "dev:db": "pnpm db:studio",
    "dev:email": "email dev --port 3001",
    "build": "next build --turbopack",
    "start": "next start",
    "checks": "pnpm exec biome check --write . && tsc --noEmit",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate && pnpm exec biome check --write migrations",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:start": "docker compose -f docker-compose.yml up -d",
    "db:stop": "docker compose -f docker-compose.yml down -v",
    "generate:auth": "pnpx @better-auth/cli generate --output ./db/schema/auth/schema.ts && pnpm exec biome check --write ./db/schema/auth/schema.ts",
    "env:pull": "vercel env pull .env",
    "sync": "git fetch template && git merge template/main",
    "sync:initial": "git fetch template && git merge template/main --allow-unrelated-histories",
    "setup:sync": "git remote get-url template >/dev/null 2>&1 && git remote set-url template https://github.com/impulse-studio/minimal-boilerplate.git || git remote add template https://github.com/impulse-studio/minimal-boilerplate.git",
    "ralph": "bash scripts/ralph-loop.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@orpc/client": "^1.8.0",
    "@orpc/server": "^1.8.0",
    "@orpc/tanstack-query": "^1.8.0",
    "@radix-ui/react-accordion": "^1.2.8",
    "@radix-ui/react-checkbox": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.12",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.3.4",
    "@radix-ui/react-scroll-area": "^1.2.6",
    "@radix-ui/react-select": "^2.2.2",
    "@radix-ui/react-slider": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.9",
    "@radix-ui/react-toast": "^1.2.11",
    "@radix-ui/react-tooltip": "^1.2.4",
    "@react-email/components": "^0.0.36",
    "@remixicon/react": "^4.6.0",
    "@t3-oss/env-nextjs": "^0.13.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-highlight": "^3.0.9",
    "@tiptap/extension-link": "^3.0.9",
    "@tiptap/extension-placeholder": "^3.0.9",
    "@tiptap/extension-typography": "^3.0.9",
    "@tiptap/extension-underline": "^3.0.9",
    "@tiptap/react": "^3.0.9",
    "@tiptap/starter-kit": "^3.0.9",
    "@vercel/blob": "^1.1.1",
    "ai": "^6.0.77",
    "better-auth": "^1.4.18",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.1.2",
    "date-fns": "^3.6.0",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.41.0",
    "merge-refs": "^1.3.0",
    "motion": "^12.8.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.4.3",
    "pg": "^8.15.5",
    "react": "19.1.0",
    "react-aria-components": "^1.8.0",
    "react-day-picker": "8.10.1",
    "react-dom": "19.1.0",
    "react-email": "^4.3.2",
    "react-hook-form": "^7.62.0",
    "react-otp-input": "^3.1.1",
    "resend": "^4.4.0",
    "sonner": "^1.7.4",
    "superjson": "^2.2.2",
    "tailwind-merge": "^2.6.0",
    "tailwind-scrollbar-hide": "^2.0.0",
    "tailwind-variants": "^0.2.1",
    "ulid": "^3.0.1",
    "usehooks-ts": "^3.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.6",
    "@types/node": "^20.19.30",
    "@types/pg": "^8.11.13",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "chalk": "^5.4.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "ultracite": "^5.0.35"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.2",
      "@types/react-dom": "19.1.2",
      "glob": ">=10.5.0",
      "vite": ">=7.0.7",
      "esbuild": ">=0.25.0",
      "brace-expansion": ">=2.0.2",
      "lodash": ">=4.17.23",
      "undici": ">=6.23.0",
      "js-yaml": ">=4.1.1"
    }
  }
}
