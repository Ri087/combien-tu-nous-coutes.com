{
    "name": "minimal-boilerplate",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "docker": "./docker/start.sh",
        "dev": "concurrently --raw --kill-others pnpm:dev:*",
        "dev:next": "next dev --turbo",
        "dev:db": "pnpm db:studio",
        "dev:email": "email dev --port 3001",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "db:studio": "drizzle-kit studio",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:start": "docker compose -f docker-compose.yml up -d",
        "db:stop": "docker compose -f docker-compose.yml down -v",
        "generate:auth": "pnpx @better-auth/cli generate --output ./db/schema/auth-schema.ts",
        "trigger:deploy": "pnpx trigger.dev@latest deploy",
        "precommit": "pnpm typecheck && pnpm lint && pnpm format"
    },
    "dependencies": {
        "@arcjet/next": "1.0.0-beta.5",
        "@radix-ui/react-accordion": "^1.2.1",
        "@radix-ui/react-checkbox": "^1.1.2",
        "@radix-ui/react-dialog": "^1.1.2",
        "@radix-ui/react-dropdown-menu": "^2.1.2",
        "@radix-ui/react-label": "^2.1.0",
        "@radix-ui/react-popover": "^1.1.2",
        "@radix-ui/react-radio-group": "^1.2.1",
        "@radix-ui/react-scroll-area": "^1.2.0",
        "@radix-ui/react-select": "^2.1.2",
        "@radix-ui/react-slider": "^1.2.1",
        "@radix-ui/react-slot": "^1.1.0",
        "@radix-ui/react-switch": "^1.1.1",
        "@radix-ui/react-tabs": "^1.1.1",
        "@radix-ui/react-toast": "^1.2.2",
        "@radix-ui/react-tooltip": "^1.1.3",
        "@remixicon/react": "^4.5.0",
        "@tanstack/react-table": "^8.21.2",
        "@upstash/ratelimit": "^2.0.5",
        "@upstash/redis": "^1.34.7",
        "ai": "^4.3.4",
        "clsx": "^2.1.1",
        "cmdk": "^1.0.4",
        "concurrently": "^9.1.2",
        "date-fns": "^3",
        "dotenv": "^16.4.7",
        "drizzle-kit": "^0.30.6",
        "drizzle-orm": "^0.41.0",
        "merge-refs": "^1.3.0",
        "motion": "^12.6.3",
        "next": "15.2.4",
        "next-themes": "^0.4.3",
        "next-zod-route": "^0.2.5",
        "nuqs": "^2.4.1",
        "pg": "^8.14.1",
        "posthog-js": "^1.235.0",
        "posthog-node": "^4.11.3",
        "react": "18.3.1",
        "react-aria-components": "^1.4.1",
        "react-day-picker": "8.10.1",
        "react-dom": "18.3.1",
        "react-email": "^4.0.6",
        "react-otp-input": "^3.1.1",
        "resend": "^4.2.0",
        "sonner": "^1.7.0",
        "tailwind-merge": "^2.5.4",
        "tailwind-scrollbar-hide": "^2.0.0",
        "tailwind-variants": "^0.2.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^20",
        "@types/pg": "^8.11.11",
        "@types/react": "^18",
        "@types/react-dom": "^18",
        "eslint": "^8",
        "eslint-config-next": "15.0.2",
        "postcss": "^8",
        "prettier": "^3.3.3",
        "prettier-plugin-tailwindcss": "^0.6.8",
        "tailwindcss": "^3.4.14",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "^5"
    }
}
